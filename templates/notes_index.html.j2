{% extends "base.html.j2" %}
{% block title %}Daily notes · Weekly Movers{% endblock %}
{% block body %}

<article style="max-width: 720px; margin: 0 auto;">
  <h2 style="font-family: var(--display); font-size: var(--t-28); margin-top: 0;">
    Daily notes
  </h2>
  <p style="color: var(--text-md);">
    Short AI-generated companion notes on each day's screen — what's notable,
    what changed versus the prior trading day. Generated by Claude Sonnet 4.6
    from the JSON-anchored screen data; sanitized server-side before render.
  </p>

  {% if notes %}
  <ul style="list-style: none; padding: 0; margin: var(--s-4) 0;">
    {% for note in notes %}
    <li style="border-top: 1px solid var(--border); padding: var(--s-3) 0;">
      <div style="color: var(--text-md); font-family: var(--mono); font-size: var(--t-12); letter-spacing: 0.08em; text-transform: uppercase;">
        {{ note.date }}
      </div>
      <a href="{{ note.date }}.html" style="font-family: var(--display); font-size: var(--t-19); display: inline-block; margin-top: var(--s-1);">
        Note for {{ note.date }} →
      </a>
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <div style="background: var(--bg-1); border: 1px solid var(--border); padding: var(--s-4); border-radius: 4px; margin-top: var(--s-4);">
    <p style="margin: 0; color: var(--text-md);">
      No notes published yet. Daily commentary will appear here once the
      <a href="https://github.com/shehral/weekly-movers/blob/main/scripts/generate_narrative.py">narrative routine</a>
      is enabled.
    </p>
  </div>
  {% endif %}
</article>
{% endblock %}
